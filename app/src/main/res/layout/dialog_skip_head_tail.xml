<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="@dimen/spacing_medium">

    <com.google.android.material.bottomsheet.BottomSheetDragHandleView
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        style="@style/Widget.Auxio.TextView.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/spacing_medium"
        android:layout_marginBottom="@dimen/spacing_tiny"
        android:text="@string/lbl_skip_head_tail" />

    <TextView
        style="@style/Widget.Auxio.TextView.Secondary.Compact"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/spacing_medium"
        android:layout_marginBottom="@dimen/spacing_medium"
        android:text="@string/lng_skip_head_tail_desc" />

    <!-- 智能判断 -->
    <LinearLayout
        android:id="@+id/skip_smart_item"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_medium"
        android:paddingVertical="@dimen/spacing_medium">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_auto_24"
            app:tint="?attr/colorOnSurface" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_medium"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                style="@style/Widget.Auxio.TextView.Primary.Compact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/lbl_skip_smart" />

            <TextView
                android:id="@+id/skip_smart_status"
                style="@style/Widget.Auxio.TextView.Secondary.Compact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/lng_skip_smart_desc" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/skip_smart_progress"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_small"
            android:visibility="gone" />
    </LinearLayout>

    <!-- 跳过开头 -->
    <LinearLayout
        android:id="@+id/skip_head_item"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_medium"
        android:paddingVertical="@dimen/spacing_medium">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_skip_next_24"
            app:tint="?attr/colorOnSurface" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_medium"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                style="@style/Widget.Auxio.TextView.Primary.Compact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/lbl_skip_head" />

            <TextView
                android:id="@+id/skip_head_status"
                style="@style/Widget.Auxio.TextView.Secondary.Compact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/fmt_skip_seconds_off" />
        </LinearLayout>
    </LinearLayout>

    <!-- 跳过结尾 -->
    <LinearLayout
        android:id="@+id/skip_tail_item"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_medium"
        android:paddingVertical="@dimen/spacing_medium">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_skip_prev_24"
            app:tint="?attr/colorOnSurface" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_medium"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                style="@style/Widget.Auxio.TextView.Primary.Compact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/lbl_skip_tail" />

            <TextView
                android:id="@+id/skip_tail_status"
                style="@style/Widget.Auxio.TextView.Secondary.Compact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/fmt_skip_seconds_off" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
